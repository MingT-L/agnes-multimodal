# ===== Agnes 多模态 API 凭据示例 =====
# 复制本文件为 .env，并填入真实值；.env 已在 .gitignore 中，不会被提交

# Agnes API 平台申请地址：https://platform.agnes-ai.com
# 路径：Settings → API Keys → Create new secret key
AGNES_API_KEY=sk-your-real-key-here

# API Base URL（一般无需修改）
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# ===== 可选：行为调优 =====

# HTTP 请求超时（秒），单次请求用
# 默认 60s；批量场景建议 120s
AGNES_HTTP_TIMEOUT=60

# 视频任务最大等待时间（秒）
# POSTMORTEM 改进：默认 600s（10 分钟），覆盖 v1 默认 300s
AGNES_VIDEO_MAX_WAIT=600

# 视频任务轮询间隔（秒）
AGNES_VIDEO_POLL_INTERVAL=5

# 输出目录（相对仓库根）
AGNES_OUTPUT_DIR=assets/outputs

# ===== 可选：批量任务（P0 改进）=====

# 批量 case 之间的间隔秒数（防 API 限流）
# POSTMORTEM 关键改进：默认 30s
AGNES_BATCH_INTERVAL=30

# 连续失败多少次后进入冷却期
AGNES_MAX_CONSECUTIVE_FAILURES=5

# ===== 可选：Prompt 翻译预处理（P1.6 改进）=====
# Agnes 视频 API 对中文支持弱（实测 0% 成功率），建议开启翻译

# 是否启用中文 → 英文翻译（true/false）
AGNES_TRANSLATE_ENABLED=false

# 翻译 provider：stub（默认内置词典）| google | openai
#   stub:    无需 API，按内置词典替换（推荐先用这个验证）
#   google:  Google Cloud Translate（需 GOOGLE_TRANSLATE_API_KEY）
#   openai:  OpenAI gpt-4o-mini（需 OPENAI_API_KEY）
AGNES_TRANSLATE_PROVIDER=stub

# 翻译目标语言
AGNES_TRANSLATE_TARGET=en

# 翻译缓存文件路径（避免重复翻译）
# AGNES_TRANSLATE_CACHE=assets/outputs/.translate_cache.json

# ===== 可选：可选 API Key（按需）=====
# 启用 Google 翻译时
# GOOGLE_TRANSLATE_API_KEY=your-google-key
# 启用 OpenAI 翻译时
# OPENAI_API_KEY=sk-your-openai-key
# 启用 OpenAI 错误分类时（auto_test.py --use-llm-classify）
# OPENAI_API_KEY=sk-your-openai-key
